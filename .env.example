# Copy to .env (or export in your shell). NEVER commit real secrets.
# .env is git-ignored.

# === Email (SMTP) ===
# Example: Gmail with an App Password.
QAGENT_SMTP_HOST=smtp.gmail.com
QAGENT_SMTP_PORT=587
QAGENT_SMTP_USER=you@example.com
QAGENT_SMTP_PASSWORD=your-app-password
QAGENT_SMTP_FROM=you@example.com
QAGENT_SMTP_TLS=1
# Use "ssl" for SMTP_SSL (port 465), "0" for plain, anything else for STARTTLS.

# === Telegram ===
# 1. Create a bot with @BotFather, copy the token.
# 2. Send your bot a message, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat id (the "id" inside "chat").
# 3. Put YOUR chat id in QAGENT_TG_ALLOWED_CHATS so only you can talk to it.
QAGENT_TG_BOT_TOKEN=123456:ABC-your-bot-token
QAGENT_TG_DEFAULT_CHAT=123456789
QAGENT_TG_ALLOWED_CHATS=123456789
